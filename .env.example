# Milvus (имя сервиса в docker-compose: milvus)
MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530
MILVUS_COLLECTION=faq_kb

# Префикс коллекций по категориям: {MILVUS_COLLECTION}_{slug_категории}

# Минимальный косинус (вопрос + подсказка к якорю категории) для выбора коллекции
CATEGORY_ROUTE_THRESHOLD=0.25

# Удалить и пересобрать индекс Milvus при старте API
REBUILD_MILVUS_INDEX=false

# Эмбеддинги (идентификатор модели sentence-transformers)
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# Чат-модель: облако OpenAI или локальный совместимый сервер (Qwen в Docker, Ollama, vLLM, LM Studio)
# Базовый URL обычно заканчивается на /v1
# Ollama: OPENAI_BASE_URL=http://127.0.0.1:11434/v1  LLM_MODEL=qwen2.5:7b
# vLLM:   OPENAI_BASE_URL=http://127.0.0.1:8000/v1   LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
# Если приложение в Docker, а модель на хосте Windows: host.docker.internal вместо 127.0.0.1
OPENAI_API_KEY=
OPENAI_BASE_URL=
LLM_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=120
OPENAI_MAX_RETRIES=2

# Параметры RAG
RAG_TOP_K=8
# Целевое число статей в контексте (добор из top-K, если семантика дала мало)
RAG_MIN_SOURCES=3
RAG_PADDING_MIN_SCORE=0.22
# Сколько лучших (после слияния и пересортировки) фрагментов отдать в модель и в sources
LLM_CONTEXT_MAX_CHUNKS=3
SCORE_THRESHOLD_NO_ANSWER=0.35
SCORE_HIGH=0.55
SCORE_MEDIUM=0.45

# Путь к mock_kb.json (по умолчанию — корень репозитория)
KB_JSON_PATH=mock_kb.json

LOG_PROMPTS=true
